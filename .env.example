# ============================================================================
# 医疗 RAG 系统 - 环境变量配置
# ============================================================================
# 复制此文件为 .env 并根据需要修改
# 用法: 在终端 export，或用 python-dotenv 加载

# ============================================================
# LLM Provider (必选 — 四选一)
# ============================================================

# 方案1: 本地 Ollama (默认)
# RAG_LLM_PROVIDER=ollama
# RAG_LLM_MODEL=qwen3.5:4b
# RAG_LLM_BASE_URL=http://localhost:11434

# 方案2: OpenAI 云端 API
# RAG_LLM_PROVIDER=openai
# RAG_LLM_MODEL=gpt-4o-mini
# RAG_LLM_API_KEY=sk-your-key-here

# 方案3: Anthropic Claude 云端 API
# RAG_LLM_PROVIDER=anthropic
# RAG_LLM_MODEL=claude-sonnet-4-6
# RAG_LLM_API_KEY=sk-ant-your-key-here

# 方案4: DeepSeek 云端 API (兼容 OpenAI 协议)
# RAG_LLM_PROVIDER=deepseek
# RAG_LLM_MODEL=deepseek-chat
# RAG_LLM_API_KEY=sk-your-key-here
# RAG_LLM_BASE_URL=https://api.deepseek.com/v1

# 通用配置
# RAG_LLM_TEMPERATURE=0.1

# ============================================================
# Embedding 模型
# ============================================================
# RAG_EMBEDDING_MODEL=shibing624/text2vec-base-chinese
# RAG_EMBEDDING_DEVICE=cpu

# ============================================================
# 文本切分
# ============================================================
# RAG_CHUNK_SIZE=500
# RAG_CHUNK_OVERLAP=50

# ============================================================
# 检索参数
# ============================================================
# RAG_RETRIEVAL_K=8
# RAG_RERANK_TOP_N=4
# RAG_BM25_WEIGHT=0.3
# RAG_VECTOR_WEIGHT=0.7
# RAG_RERANK_MODEL=BAAI/bge-reranker-large
# RAG_RERANK_ENABLED=true

# ============================================================
# OCR
# ============================================================
# RAG_OCR_ENABLED=false

# ============================================================
# LangSmith 追踪 (可选)
# ============================================================
# LANGSMITH_API_KEY=your_key_here
# LANGSMITH_PROJECT=medical-rag
